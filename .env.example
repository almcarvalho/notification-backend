DATABASE_URL="postgresql://postgres:postgres@localhost:5432/notification_db?schema=public"
PORT=3000
NODE_ENV=development

# Controle das rotas de gerência de API keys
IS_MANAGER_ON=true

# Header com a chave de autenticação nas rotas protegidas
API_KEY_HEADER=x-api-key

# Jobs
PROCESSING_INTERVAL_MINUTES=2
CRON_DAILY_SUMMARY=0 20 * * *
JOB_TIMEZONE=America/Sao_Paulo

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+10000000000
TWILIO_CALL_FROM=+10000000000

# Resend
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Admin (resumo diário via WhatsApp)
ADMIN_WHATSAPP_TO=whatsapp:+5500000000000
